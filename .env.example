# -------------------------------------------------------
# Ballistic — Environment Variables Template
# Copy this file to .env and fill in your real keys.
# NEVER commit .env to git.
# -------------------------------------------------------

# Groq API — free tier (6,000 req/day)
# Get your key at: console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Cache settings (optional — these are the defaults)
# Individual data sources override this: odds=2h, stats=6h, NFL EPA=12h, win totals=24h
CACHE_TTL_HOURS=6
CACHE_DIR=data/cache
